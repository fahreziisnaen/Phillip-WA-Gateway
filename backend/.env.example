# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Legacy API key (still works, but prefer managing keys via the Settings UI)
API_KEY=

# JWT secret for dashboard session (openssl rand -hex 32)
JWT_SECRET=change_this_to_a_secure_random_jwt_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Paths ─────────────────────────────────────────────────────────────────────
SESSION_DIR=./sessions
LOG_FILE=./logs/messages.log
