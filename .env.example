# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Gateway — Environment Variables
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3000

# (Optional) Legacy static API key for external integrations.
# API keys are normally generated from the dashboard: Settings → API Keys.
# Only set this if you need a fixed key without logging in to the dashboard.
API_KEY=

# Secret used to sign JWT session tokens for the admin dashboard.
# Generate a strong value: openssl rand -hex 32
JWT_SECRET=change_this_to_a_secure_random_jwt_secret

# ── Redis (must match docker-compose service name) ────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database file path (set automatically via docker-compose environment)
DB_PATH=/app/data/gateway.db

# ── Paths (relative to the backend container's /app working directory) ────────
SESSION_DIR=./sessions

# ── Frontend build (VITE_ prefix exposes vars to the browser bundle) ──────────
# Not required — the admin dashboard authenticates via username/password (JWT).
# Only needed for legacy direct API key usage from the frontend.
VITE_API_KEY=
